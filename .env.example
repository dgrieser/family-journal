APP_ENV=development
PORT=8080

MYSQL_ROOT_PASSWORD='change-me'
MYSQL_DATABASE='familyjournal'
MYSQL_DSN="root:${MYSQL_ROOT_PASSWORD:-change-me}@tcp(mysql:3306)/familyjournal?parseTime=true"

SESSION_SECRET='replace-with-long-random-secret'
CORS_ALLOW_ORIGINS='http://localhost:5173'
COOKIE_SECURE=false
UPLOAD_DIR='./uploads'
MAX_UPLOAD_MB=25
DB_MAX_OPEN=10
DB_MAX_IDLE=5
DB_MAX_LIFETIME_MINUTES=5
ALLOWED_UPLOAD_TYPES='image/jpeg,image/png,application/pdf'
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_SECONDS=60

# ADMIN_EMAIL='admin@example.com'

# Email (SMTP) — all optional; if SMTP_HOST is not set, no emails are sent
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=secret
# SMTP_FROM=noreply@example.com
