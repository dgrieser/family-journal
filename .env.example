APP_ENV=development
PORT=8080

MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=familyjournal
MYSQL_DSN=root:change-me@tcp(mysql:3306)/familyjournal?parseTime=true

SESSION_SECRET=replace-with-long-random-secret
CORS_ALLOW_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
DB_MAX_OPEN=10
DB_MAX_IDLE=5
DB_MAX_LIFETIME_MINUTES=5
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,application/pdf
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_SECONDS=60
